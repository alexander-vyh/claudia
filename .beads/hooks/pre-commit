#!/usr/bin/env sh
# --- BEGIN BEADS INTEGRATION v0.59.0 ---
# This section is managed by beads. Do not remove these markers.
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  bd hooks run pre-commit "$@"
  _bd_exit=$?; if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v0.59.0 ---

# --- BEGIN GITLEAKS ---
# Prevent committing secrets (was in .git/hooks/pre-commit before beads moved hooksPath)
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --no-banner
  if [ $? -ne 0 ]; then
    echo "gitleaks: secrets detected in staged files. Commit blocked."
    exit 1
  fi
fi
# --- END GITLEAKS ---

# --- BEGIN PII CHECK ---
if command -v python3 >/dev/null 2>&1 && [ -f scripts/check_pii_patterns.py ]; then
  STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
  if [ -n "$STAGED_FILES" ]; then
    printf '%s\0' $STAGED_FILES | xargs -0 python3 scripts/check_pii_patterns.py
    if [ $? -ne 0 ]; then
      exit 1
    fi
  fi
fi
# --- END PII CHECK ---
